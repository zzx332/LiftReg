{
    "dataset": {
        "apply_hu_clip": true,
        "data_path": "/home/zzx/extracted_data_shift_only3",
        "val_data_path": "/home/zzx/data/data/test_shift_only_06",
        "dataset_class": "liftreg.dataset.FluoroDataset2D.FluoroDataset2D",
        "drr_folder_name": "diffdrr",
        "img_after_resize": [160, 160],
        "load_projection_interval": 1,
        "load_training_data_into_memory": true,
        "max_num_for_loading": [100, 20, 10, 10],
        "spacing_to_refer": [2.2, 2.2, 2.2],
        "use_segmentation_map": true,
        "augmentation_enable": false,
        "aug_noise_prob": 0.5
    },
    "train": {
        "check_best_model_frequency": 1,
        "dataloader": {
            "batch_size": 2,
            "shuffle": [true, true, false, false],
            "workers": [4, 4, 0, 0]
        },
        "debug_on": true,
        "memory_profile": true,
        "epoch": 1000,
        "gpu_ids": 0,
        "loss": {
            "sim_factor": 1.0,
            "reg_factor": 1.0,
            "use_dice": false
        },
        "loss_class": "liftreg.losses.RegLoss2D.loss",
        "mode": "train",
        "model_class": "liftreg.models.RegNet2D.RegNet2D",
        "optim": {
            "adam": {
                "beta": [0.9, 0.999],
                "weight_decay": 0
            },
            "lr": 0.0001,
            "lr_scheduler": {
                "custom": {
                    "gamma": 0.5,
                    "step_size": 100
                },
                "type": "custom"
            },
            "optim_type": "adam"
        },
        "output_path": "/home/zzx/data/exp_liftreg_2d",
        "save_model_frequency": 50,
        "val_frequency": 20
    }
}
